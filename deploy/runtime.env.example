# Copy to deploy/runtime.env and fill in secrets before using scripts/run-*.sh.
# This template is for host-level services fronted by nginx at https://app.ctlplumbingllc.com.

# Backing services published by docker compose on the same host
POSTGRES_USER=plumbprice
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plumbprice
DATABASE_URL=postgresql+asyncpg://plumbprice:change-me@127.0.0.1:5436/plumbprice

REDIS_URL=redis://127.0.0.1:6380/0
CELERY_BROKER_URL=redis://127.0.0.1:6380/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6380/1

MINIO_ENDPOINT=127.0.0.1:9005
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_SECURE=false
MINIO_BUCKET_BLUEPRINTS=blueprints
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PROPOSALS=proposals

# App auth and runtime
SECRET_KEY=change-me-to-a-random-32-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=production
LOG_LEVEL=WARNING

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Optional local inference
HERMES_ENDPOINT_URL=http://127.0.0.1:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=ollama
LLM_TIMEOUT=12.0
LLM_CLASSIFY_THRESHOLD=0.75

# Browser origin and standalone service ports
PUBLIC_HOST=app.ctlplumbingllc.com
API_URL=https://app.ctlplumbingllc.com
NEXT_PUBLIC_API_URL=https://app.ctlplumbingllc.com
CORS_ORIGINS=["https://app.ctlplumbingllc.com"]
API_PORT=8201
WEB_PORT=3201
NEXT_INTERNAL_PORT=3202

# Optional integrations
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RESEND_API_KEY=
EMAIL_FROM=estimates@ctlplumbingllc.com
