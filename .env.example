# Database
POSTGRES_USER=plumbprice
POSTGRES_PASSWORD=plumbprice_dev
POSTGRES_DB=plumbprice
DATABASE_URL=postgresql+asyncpg://plumbprice:plumbprice_dev@localhost:5432/plumbprice

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_BLUEPRINTS=blueprints
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PROPOSALS=proposals

# Auth
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Providers — cloud (optional fallback)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# AI — Hermes 3 via Ollama (primary LLM for intent classification + responses)
# Setup: ollama pull hermes3 && ollama serve
HERMES_ENDPOINT_URL=http://localhost:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=ollama
LLM_TIMEOUT=12.0
LLM_CLASSIFY_THRESHOLD=0.75

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
PUBLIC_HOST=100.83.120.32
API_PORT=8200
WEB_PORT=3200
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3200", "http://100.83.120.32:3200"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Frontend
NEXT_PUBLIC_API_URL=http://100.83.120.32:8200
