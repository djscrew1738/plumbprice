# Database
POSTGRES_USER=plumbprice
POSTGRES_PASSWORD=plumbprice_dev
POSTGRES_DB=plumbprice
DATABASE_URL=postgresql+asyncpg://plumbprice:plumbprice_dev@localhost:5432/plumbprice

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_BLUEPRINTS=blueprints
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_PROPOSALS=proposals

# Auth
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Providers — cloud (optional fallback)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# AI — Ollama (OpenAI-compatible local inference)
# Docker Compose on Linux reaches the host-side Ollama tunnel through host.docker.internal.
HERMES_ENDPOINT_URL=http://host.docker.internal:11434/v1
LLM_PRIMARY_MODEL=qwen3:8b
LLM_SECONDARY_MODEL=hermes3:3b
LLM_EMBEDDING_MODEL=mxbai-embed-large
LLM_VISION_MODEL=minicpm-o2.6
HERMES_MODEL=qwen3:8b
HERMES_API_KEY=ollama
LLM_TIMEOUT=12.0
LLM_CLASSIFY_THRESHOLD=0.75

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
PUBLIC_HOST=app.ctlplumbingllc.com
API_PORT=8201
WEB_PORT=3201
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3200", "https://app.ctlplumbingllc.com"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Frontend
NEXT_PUBLIC_API_URL=https://app.ctlplumbingllc.com
